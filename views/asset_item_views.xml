<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== LIST VIEW ==================== -->
    <record id="view_asset_item_list" model="ir.ui.view">
        <field name="name">asset.item.list</field>
        <field name="model">asset.item</field>
        <field name="arch" type="xml">
            <list string="Asset Items" editable="bottom">
                <field name="name" string="Item Name"/>
                <field name="asset_class" string="Asset Class" readonly="1"/>
                <field name="asset_category" string="Asset Category"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ==================== FORM VIEW ==================== -->
    <record id="view_asset_item_form" model="ir.ui.view">
        <field name="name">asset.item.form</field>
        <field name="model">asset.item</field>
        <field name="arch" type="xml">
            <form string="Asset Item">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Item Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="asset_category" options="{'no_create': False}"/>
                            <field name="asset_class" readonly="1"/>
                        </group>
                        <group string="Status">
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== SEARCH VIEW ==================== -->
    <record id="view_asset_item_search" model="ir.ui.view">
        <field name="name">asset.item.search</field>
        <field name="model">asset.item</field>
        <field name="arch" type="xml">
            <search string="Search Asset Items">
                <field name="name" string="Item Name"
                       filter_domain="[('name', 'ilike', self)]"/>
                <field name="asset_category" string="Category"/>
                <field name="asset_class" string="Class"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Asset Class" name="group_class"
                            context="{'group_by': 'asset_class'}"/>
                    <filter string="Asset Category" name="group_category"
                            context="{'group_by': 'asset_category'}"/>
                    <filter string="Active" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="action_asset_item" model="ir.actions.act_window">
        <field name="name">Asset Items</field>
        <field name="res_model">asset.item</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_asset_item_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Asset Item
            </p>
            <p>Items are the most granular level of asset classification under Class → Category → Item.</p>
        </field>
    </record>

</odoo>
