<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_asset_asset_form" model="ir.ui.view">
        <field name="name">asset.asset.form</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <form string="Asset">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
<!--                    <field name="qr_code_image" widget="image" class="oe_avatar" readonly="1" options="{'size': [90, 90]}"/>-->
                    <field name="qr_code_image" widget="image" class="oe_avatar" readonly="1" options="{'zoom': true, 'zoom_delay': 1000, 'preview_image':'qr_code_image'}"/>
<!--                    <field name="image" widget="image"  class="oe_avatar"/>-->

                    <div class="oe_title">
                        <label for="asset_name" string="Asset Name"/>
                        <h1><field name="asset_name" placeholder="e.g. Dell XPS 15"/></h1>
                        <h3><field name="qr_number" readonly="1"/></h3>
                    </div>

                    <group>
                        <group string="Classification">
                            <field name="asset_class" readonly="id" options="{'no_create': True}"/>
                            <field name="asset_category"/>
                            <field name="asset_item"/>
                            <field name="asset_brand"/>
                            <field name="qty"/>
                            <field name="asset_model"/>
                            <field name="description"/>
                            <field name="jv_voucher"/>
                            <field name="bd_voucher"/>
                        </group>
                        <group string="General Info">
                            <field name="purchase_date"/>
                            <field name="supplier"/>
                            <field name="manufacture_sn"/>
                            <field name="f_year"/>
                            <field name="color"/>
                            <field name="have_warranty"/>
                            <field name="warranty" invisible="have_warranty == False" placeholder="e.g. 12"/>
                        </group>
                    </group>

                    <group string="Asset Value &amp; Depreciation Info">
                        <group>
                            <field name="asset_value" required="1" placeholder="Value must be greater than 0"/>
                            <field name="registration_amount"/>
                            <field name="installation_cost"/>
                            <field name="insurance_cost"/>
                        </group>
                        <group>
                            <field name="other_cost"/>
                            <field name="vat_amount"/>
                            <field name="tds_amount"/>
                            <field name="total" readonly="1" force_save="1"/>
                            <field name="is_depreciation" string="Depreciation"/>
                        </group>
                    </group>

                    <group string="Asset Location">
                        <group>
                            <field name="company" required="1" placeholder="Choose An Option"/>
                            <field name="division" required="1" placeholder="Choose An Option"/>
                            <field name="department" required="1" placeholder="Choose An Option"/>
                        </group>
                        <group>
                            <field name="office_location" required="1" placeholder="Choose An Option"/>
                            <field name="asset_floor_location" required="1" placeholder="Choose An Option"/>
                        </group>
                    </group>

                    <group string="Services &amp; Accessories">
                        <group>
                            <field name="services" widget="many2many_tags" placeholder="Choose an option"/>
                            <field name="accessories" widget="many2many_tags" placeholder="Choose an option"/>
                            <field name="tags" widget="many2many_tags" placeholder="Choose an option"/>
                        </group>
                        <group>
                            <field name="description" string="Remarks" placeholder="Enter remarks..."/>
                        </group>
                    </group>

                    <!-- ── Compound Asset toggle ── -->
                    <group string="Compound Asset">
                        <field name="is_compound_asset" string="Make it Compound Asset"
                               widget="boolean_toggle"/>
                        <field name="parent_asset_id"
                               invisible="is_compound_asset"
                               domain="[('is_compound_asset', '=', True), ('id', '!=', id)]"
                               placeholder="Select parent compound asset..."
                               options="{'no_create': True}"/>
                    </group>

                    <!-- ── Component Assets (shown only when is_compound_asset) ── -->
                    <notebook invisible="not is_compound_asset">
                        <page string="Component Assets" name="components">
                            <div class="alert alert-info mb-3" role="alert">
                                <i class="fa fa-info-circle me-2"/>
                                Select the existing individual assets that make up this compound asset.
                            </div>

                            <field name="child_asset_ids"
                                   widget="many2many"
                                   domain="[('id', '!=', id), ('is_compound_asset', '=', False), ('parent_asset_id', '=', False)]"
                                   context="{'default_parent_asset_id': id}"
                                   options="{'no_create': True}">
                                <list>
                                    <field name="qr_number"     string="QR No."/>
                                    <field name="asset_name"    string="Component Name"/>
                                    <field name="asset_category" string="Category"/>
                                    <field name="asset_brand"   string="Brand"/>
                                    <field name="state"         string="Status"
                                           widget="badge"
                                           decoration-success="state == 'active'"
                                           decoration-danger="state == 'broken'"/>
                                </list>
                            </field>

                            <group class="mt-3" invisible="component_count == 0">
                                <group string="Summary">
                                    <field name="component_count" string="Total Components" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>

                </sheet>

                <div class="o_attachment_preview o_center_attachment"/>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_asset_asset_list" model="ir.ui.view">
        <field name="name">asset.asset.list</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <list string="Assets" decoration-muted="state == 'idle'" decoration-danger="state == 'broken'">
                <field name="qr_code_image" widget="image" class="oe_avatar" readonly="1" options="{'zoom': true, 'zoom_delay': 1000, 'preview_image':'qr_code_image'}"/>
                <field name="qr_number" string="QR Number"/>
                <field name="asset_class" readonly="id" options="{'no_create': True}"/>
                <field name="asset_category"/>
                <field name="asset_item"/>
                <field name="asset_brand"/>
                <field name="asset_model"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state in ('faulty', 'in_servicing')"
                       decoration-danger="state == 'broken'"
                       decoration-info="state == 'idle'"/>
                <field name="description"/>
                <field name="jv_voucher"/>
                <field name="bd_voucher"/>
                <field name="qty"/>
                <field name="purchase_date"/>
                <field name="supplier"/>
                <field name="manufacture_sn"/>
                <field name="f_year"/>
                <field name="color"/>
                <field name="have_warranty"/>
                <field name="warranty"/>
                <field name="asset_value"/>
                <field name="registration_amount"/>
                <field name="installation_cost"/>
                <field name="insurance_cost"/>
                <field name="other_cost"/>
                <field name="vat_amount"/>
                <field name="tds_amount"/>
                <field name="total"/>
                <field name="company"/>
                <field name="division"/>
                <field name="department"/>
                <field name="is_depreciation"/>
                <field name="office_location"/>
                <field name="asset_floor_location"/>
            </list>
        </field>
    </record>

    <record id="view_asset_asset_search" model="ir.ui.view">
        <field name="name">asset.asset.search</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <search string="Search Assets">
                <field name="asset_name"/>
                <field name="qr_number"/>
                <field name="manufacture_sn"/>
                <field name="asset_class"/>
                <separator/>
                <filter string="Active Assets" name="active_assets" domain="[('state', '=', 'active')]"/>
                <filter string="In Servicing" name="servicing" domain="[('state', '=', 'in_servicing')]"/>
                <filter string="Has Warranty" name="warranty" domain="[('have_warranty', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by':'asset_category'}"/>
                    <filter string="Location" name="group_location" context="{'group_by':'office_location'}"/>
                    <filter string="State" name="group_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_asset_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">asset.asset</field>
        <field name="view_mode">list,form</field>
        <field name="context">{"search_default_active_assets": 1}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Create your first Asset!
          </p>
          <p>
            Track your hardware, manage depreciations, and generate QR codes automatically.
          </p>
        </field>
    </record>

</odoo>