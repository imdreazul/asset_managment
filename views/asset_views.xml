<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_asset_asset_form" model="ir.ui.view">
        <field name="name">asset.asset.form</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <form string="Asset">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
<!--                    <field name="qr_code_image" widget="image" class="oe_avatar" readonly="1" options="{'size': [90, 90]}"/>-->
                    <field name="qr_code_image" widget="image" class="oe_avatar" readonly="1" options="{'zoom': true, 'zoom_delay': 1000, 'preview_image':'qr_code_image'}"/>
<!--                    <field name="image" widget="image"  class="oe_avatar"/>-->

                    <div class="oe_title">
                        <label for="asset_name" string="Asset Name"/>
                        <h1><field name="asset_name" placeholder="e.g. Dell XPS 15"/></h1>
                        <h3><field name="qr_number" readonly="1"/></h3>
                    </div>

                    <group>
                        <group string="Classification">
                            <field name="asset_class" readonly="id" options="{'no_create': True}"/>
                            <field name="asset_category"/>
                            <field name="asset_item"/>
                            <field name="asset_brand"/>
                            <field name="qty"/>
                            <field name="asset_model"/>
                            <field name="description"/>
                            <field name="jv_voucher"/>
                            <field name="bd_voucher"/>
                        </group>
                        <group string="General Info">
                            <field name="asset_user"/>
                            <field name="purchase_date"/>
                            <field name="supplier"/>
                            <field name="manufacture_sn"/>
                            <field name="f_year"/>
                            <field name="color"/>
                            <field name="have_warranty"/>
                            <field name="warranty" invisible="have_warranty == False" placeholder="e.g. 12"/>
                        </group>
                    </group>

                    <group string="Asset Value &amp; Depreciation Info">
                        <group>
                            <field name="asset_value" required="1" placeholder="Value must be greater than 0"/>
                            <field name="registration_amount"/>
                            <field name="installation_cost"/>
                            <field name="insurance_cost"/>
                        </group>
                        <group>
                            <field name="other_cost"/>
                            <field name="vat_amount"/>
                            <field name="tds_amount"/>
                            <field name="total" readonly="1" force_save="1"/>
                            <field name="is_depreciation" string="Depreciation Applicable"/>
                        </group>
                    </group>

                    <!-- ── Depreciation Configuration (shown when is_depreciation is on) ── -->
                    <group string="Depreciation Configuration"
                           invisible="not is_depreciation">
                        <group>
                            <field name="depreciation_method"
                                   placeholder="Select Method..."
                                   required="is_depreciation"/>
                            <field name="depreciation_rate"
                                   invisible="depreciation_method == 'km_per_hour'"
                                   placeholder="e.g. 20 for 20% p.a."/>
                            <field name="depreciation_start_date"
                                   required="is_depreciation"/>
                        </group>
                        <group>
                            <field name="expected_km"
                                   invisible="depreciation_method != 'km_per_hour'"
                                   placeholder="Total expected KM / copies / services"/>
                            <field name="residual_value"
                                   placeholder="Residual / Scrap / Transfer Value"/>
                            <field name="depreciation_line_count"
                                   string="Schedule Lines"
                                   readonly="1"/>
                        </group>
                    </group>

                    <!-- ── Depreciation Action Buttons ── -->
                    <div class="o_row mt-2 mb-2" invisible="not is_depreciation">
                        <button name="action_generate_dep_lines"
                                string="Generate Schedule"
                                type="object"
                                class="btn btn-primary me-2"
                                icon="fa-calendar-plus-o"/>
                        <button name="action_propagate_dep_balances"
                                string="Re-Link Opening Balances"
                                type="object"
                                class="btn btn-secondary"
                                icon="fa-refresh"
                                confirm="This will overwrite all opening balances from previous period closing values. Proceed?"/>
                    </div>

                    <group string="Asset Insurance &amp; Reminder">

                        <group>
                            <field name="is_insurance"/>
                            <field name="insurance_partner_id" invisible="is_insurance == False" placeholder="Choose An Option"/>
                            <field name="insurance_type" invisible="is_insurance == False" placeholder="Choose An Option"/>
                            <field name="initial_payment" invisible="is_insurance == False"/>
                            <field name="premium_date" invisible="is_insurance == False"/>
                            <field name="insurance_complete_date" invisible="is_insurance == False"/>
                            <field name="claim_n_impact" invisible="is_insurance == False"/>
                        </group>
                        <group>
                            <field name="is_reminder"/>
                            <field name="reminder_title" invisible="is_reminder == False"/>
                            <field name="reminder_type" invisible="is_reminder == False" placeholder="Choose An Option"/>
                            <field name="reminder_date" invisible="is_reminder == False"/>
                        </group>
                    </group>

                    <group string="Asset Location">
                        <group>
                            <field name="company" required="1" placeholder="Choose An Option"/>
                            <field name="division" required="1" placeholder="Choose An Option"/>
                            <field name="department" required="1" placeholder="Choose An Option"/>
                        </group>
                        <group>
                            <field name="office_location" required="1" placeholder="Choose An Option"/>
                            <field name="asset_floor_location" required="1" placeholder="Choose An Option"/>
                        </group>
                    </group>

                    <group string="Services &amp; Accessories">
                        <group>
                            <field name="services" widget="many2many_tags" placeholder="Choose an option"/>
                            <field name="accessories" widget="many2many_tags" placeholder="Choose an option"/>
                            <field name="tags" widget="many2many_tags" placeholder="Choose an option"/>
                        </group>
                        <group>
                            <field name="remarks" string="Remarks" placeholder="Enter remarks..."/>
                        </group>
                    </group>

                    <!-- ── Compound Asset toggle ── -->
                    <group string="Compound Asset">
                        <field name="is_compound_asset" string="Make it Compound Asset"
                               widget="boolean_toggle"/>
                        <field name="parent_asset_id"
                               invisible="is_compound_asset"
                               domain="[('is_compound_asset', '=', True), ('id', '!=', id)]"
                               placeholder="Select parent compound asset..."
                               options="{'no_create': True}"/>
                    </group>

                    <!-- ── Component Assets (shown only when is_compound_asset) ── -->
                    <notebook invisible="not is_compound_asset">
                        <page string="Component Assets" name="components">
                            <div class="alert alert-info mb-3" role="alert">
                                <i class="fa fa-info-circle me-2"/>
                                Select the existing individual assets that make up this compound asset.
                            </div>

                            <field name="child_asset_ids"
                                   widget="many2many"
                                   domain="[('id', '!=', id), ('is_compound_asset', '=', False), ('parent_asset_id', '=', False)]"
                                   context="{'default_parent_asset_id': id}"
                                   options="{'no_create': True}">
                                <list>
                                    <field name="qr_number"     string="QR No."/>
                                    <field name="asset_name"    string="Component Name"/>
                                    <field name="asset_category" string="Category"/>
                                    <field name="asset_brand"   string="Brand"/>
                                    <field name="state"         string="Status"
                                           widget="badge"
                                           decoration-success="state == 'active'"
                                           decoration-danger="state == 'broken'"/>
                                </list>
                            </field>

                            <group class="mt-3" invisible="component_count == 0">
                                <group string="Summary">
                                    <field name="component_count" string="Total Components" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>

                    <!-- ── Depreciation Schedule Tab ── -->
                    <notebook invisible="not is_depreciation">
                        <page string="Depreciation Schedule" name="depreciation_schedule">

                            <div class="alert alert-info mb-3" role="alert">
                                <i class="fa fa-info-circle me-2"/>
                                <strong>How to use:</strong>
                                Click <b>Generate Schedule</b> above to auto-create period lines.
                                Then adjust <b>Cost Addition / Adjustment</b> and
                                <b>Depreciation Adjustment</b> columns as needed.
                                Use <b>Re-Link Opening Balances</b> to re-chain all periods after any manual edits.
                            </div>

                            <!-- Method legend -->
                            <div class="row mb-3">
                                <div class="col-12">
                                    <span class="badge bg-primary me-2"
                                          invisible="depreciation_method != 'reducing'">
                                        Reducing Method
                                    </span>
                                    <span class="badge bg-success me-2"
                                          invisible="depreciation_method != 'straight_line'">
                                        Straight Line
                                    </span>
                                    <span class="badge bg-warning text-dark me-2"
                                          invisible="depreciation_method != 'km_per_hour'">
                                        KM / Per Hour
                                    </span>
                                </div>
                            </div>

                            <field name="depreciation_line_ids"
                                   context="{'default_asset_id': id}">
                                <list string="Depreciation Lines"
                                      editable="bottom"
                                      decoration-info="written_down_value &gt; 0"
                                      decoration-muted="written_down_value &lt;= 0">

                                    <field name="period_type"   string="Period"/>
                                    <field name="date_from"     string="From"/>
                                    <field name="date_to"       string="To"/>
                                    <field name="days"          string="Days"   readonly="1"/>
                                    <field name="months"        string="Months" readonly="1" optional="hide"/>
                                    <field name="years"         string="Years"  readonly="1" optional="hide" digits="[16,4]"/>

                                    <!-- COST -->
                                    <field name="cost_opening_balance"  string="Cost Opening" digits="[16,2]"/>
                                    <field name="cost_addition"         string="+ Addition"   digits="[16,2]"/>
                                    <field name="cost_adjustment"       string="- Adjustment" digits="[16,2]"/>
                                    <field name="cost_closing_balance"  string="Cost Closing" digits="[16,2]" readonly="1"/>

                                    <!-- KM usage – only relevant for km_per_hour -->
                                    <field name="km_this_period"
                                           string="KM / Usage"
                                           digits="[16,2]"
                                           optional="hide"/>

                                    <!-- DEPRECIATION -->
                                    <field name="dep_opening_balance"   string="Dep Opening"  digits="[16,2]"/>
                                    <field name="dep_charge"            string="Dep Charge"   digits="[16,2]" readonly="1"/>
                                    <field name="dep_adjustment"        string="Dep Adj."     digits="[16,2]"/>
                                    <field name="dep_closing_balance"   string="Dep Closing"  digits="[16,2]" readonly="1"/>

                                    <!-- WDV -->
                                    <field name="written_down_value"    string="WDV"          digits="[16,2]" readonly="1"/>

                                    <field name="depreciation_method"   column_invisible="1"/>
                                </list>
                            </field>

                        </page>
                    </notebook>

                </sheet>

                <div class="o_attachment_preview o_center_attachment"/>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_asset_asset_list" model="ir.ui.view">
        <field name="name">asset.asset.list</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <list string="Assets" decoration-muted="state == 'idle'" decoration-danger="state == 'broken'">
                <field name="qr_code_image" widget="image" class="oe_avatar" readonly="1" options="{'zoom': true, 'zoom_delay': 1000, 'preview_image':'qr_code_image'}"/>
                <field name="qr_number" string="QR Number"/>
                <field name="asset_name"/>
                <field name="asset_class" readonly="id" options="{'no_create': True}"/>
                <field name="asset_category"/>
                <field name="asset_item"/>
                <field name="asset_brand"/>
                <field name="asset_model"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state in ('faulty', 'in_servicing')"
                       decoration-danger="state == 'broken'"
                       decoration-info="state == 'idle'"/>
                <field name="asset_user"/>
                <field name="description"/>
                <field name="jv_voucher"/>
                <field name="bd_voucher"/>
                <field name="qty"/>
                <field name="purchase_date"/>
                <field name="supplier"/>
                <field name="manufacture_sn"/>
                <field name="f_year"/>
                <field name="color"/>
                <field name="have_warranty"/>
                <field name="warranty"/>
                <field name="asset_value"/>
                <field name="registration_amount"/>
                <field name="installation_cost"/>
                <field name="insurance_cost"/>
                <field name="other_cost"/>
                <field name="vat_amount"/>
                <field name="tds_amount"/>
                <field name="total"/>
                <field name="company"/>
                <field name="division"/>
                <field name="department"/>
                <field name="is_depreciation"/>
                <field name="office_location"/>
                <field name="asset_floor_location"/>
            </list>
        </field>
    </record>

    <record id="view_asset_asset_search" model="ir.ui.view">
        <field name="name">asset.asset.search</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <search string="Search Assets">
                <field name="asset_name"/>
                <field name="qr_number"/>
                <field name="asset_class"/>
                <field name="asset_category"/>
                <field name="asset_item"/>
                <field name="supplier"/>
                <field name="asset_brand"/>
                <field name="manufacture_sn"/>
                <separator/>
                <filter string="Active Assets" name="active_assets" domain="[('state', '=', 'active')]"/>
                <filter string="Idle" name="idle" domain="[('state', '=', 'idle')]"/>
                <filter string="In Servicing" name="servicing" domain="[('state', '=', 'in_servicing')]"/>
                <filter string="Faulty" name="faulty" domain="[('state', '=', 'faulty')]"/>
                <filter string="Has Warranty" name="warranty" domain="[('have_warranty', '=', True)]"/>
                <filter string="Compound Asset" name="is_compound_asset" domain="[('is_compound_asset', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_category" context="{'group_by':'asset_category'}"/>
                    <filter string="Location" name="group_location" context="{'group_by':'office_location'}"/>
                    <filter string="Supplier" name="group_supplier" context="{'group_by':'supplier'}"/>
                    <filter string="Asset Class" name="group_asset_class" context="{'group_by':'asset_class'}"/>
                    <filter string="Asset Category" name="group_asset_category" context="{'group_by':'asset_category'}"/>
                    <filter string="Asset Brand" name="group_asset_brand" context="{'group_by':'asset_brand'}"/>
                    <filter string="State" name="group_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_asset_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">asset.asset</field>
        <field name="view_mode">list,form</field>
        <field name="context">{"search_default_active_assets": 1}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Create your first Asset!
          </p>
          <p>
            Track your hardware, manage depreciations, and generate QR codes automatically.
          </p>
        </field>
    </record>

</odoo>