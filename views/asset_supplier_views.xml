<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== LIST VIEW ==================== -->
    <record id="view_asset_supplier_list" model="ir.ui.view">
        <field name="name">asset.supplier.list</field>
        <field name="model">asset.supplier</field>
        <field name="arch" type="xml">
            <list string="Supplier Info">
                <field name="name"/>
                <field name="secondary_email"/>
                <field name="primary_email"/>
                <field name="phone"/>
                <field name="status"/>
            </list>
        </field>
    </record>
    <record id="view_asset_supplier_form" model="ir.ui.view">
        <field name="name">asset.supplier.form</field>
        <field name="model">asset.supplier</field>
        <field name="arch" type="xml">
            <form string="Supplier Info">
                <header>
                    <field name="status"
                           widget="statusbar"
                           options="{'clickable': '1'}"
                           statusbar_visible="pending,active,inactive,suspended"/>
                </header>
                <sheet>
<!--                    <div class="oe_title">-->
<!--                        <h1>New Supplier Info</h1>-->
<!--                    </div>-->
                    <group>
                        <group>
                            <field name="name" placeholder="e.g. Acme Corp"/>
                            <field name="primary_email" widget="email"/>
                            <field name="secondary_email" widget="email"/>
                            <field name="phone" widget="phone"/>
                            <field name="website" widget="url" placeholder="e.g. https://www.acme.com"/>
                        </group>

                        <group>
                            <field name="contact_name"/>
                            <field name="contact_phone" widget="phone"/>
                            <field name="contact_secondary_phone" widget="phone"/>
                            <field name="contact_email" widget="email"/>
                            <field name="address" placeholder="Enter full address..."/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_asset_supplier" model="ir.actions.act_window">
        <field name="name">Suppliers</field>
        <field name="res_model">asset.supplier</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>