<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== LIST VIEW ==================== -->
    <record id="view_asset_company_list" model="ir.ui.view">
        <field name="name">asset.company.list</field>
        <field name="model">asset.company</field>
        <field name="arch" type="xml">
<!--            <list string="Asset Companies" editable="bottom">-->
            <list string="Asset Companies">
                <field name="name" string="Company Name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ==================== FORM VIEW ==================== -->
    <record id="view_asset_company_form" model="ir.ui.view">
        <field name="name">asset.company.form</field>
        <field name="model">asset.company</field>
        <field name="arch" type="xml">
            <form string="Asset Company">
                <sheet>
                    <field name="logo" widget="image" class="oe_avatar" options="{'size': [90, 90]}"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Company Name..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== SEARCH VIEW ==================== -->
    <record id="view_asset_company_search" model="ir.ui.view">
        <field name="name">asset.company.search</field>
        <field name="model">asset.company</field>
        <field name="arch" type="xml">
            <search string="Search Asset Companies">
                <field name="name" string="Company Name"
                       filter_domain="[('name', 'ilike', self)]"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Active" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="action_asset_company" model="ir.actions.act_window">
        <field name="name">Asset Companies</field>
        <field name="res_model">asset.company</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_asset_company_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Asset Company
            </p>
            <p>Asset Companies are used to classify assets by their owning company.</p>
        </field>
    </record>

</odoo>
