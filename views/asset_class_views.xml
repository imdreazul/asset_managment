<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== LIST VIEW ==================== -->
    <record id="view_asset_class_list" model="ir.ui.view">
        <field name="name">asset.class.list</field>
        <field name="model">asset.class</field>
        <field name="arch" type="xml">
            <list string="Asset Classes" editable="bottom">
                <field name="name" string="Class Name"/>
                <field name="category_count" string="Categories"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ==================== FORM VIEW ==================== -->
    <record id="view_asset_class_form" model="ir.ui.view">
        <field name="name">asset.class.form</field>
        <field name="model">asset.class</field>
        <field name="arch" type="xml">
            <form string="Asset Class">
                <sheet>
<!--                    <div class="oe_button_box" name="button_box">-->
<!--                        <button name="%(action_asset_category)s"-->
<!--                                type="action"-->
<!--                                class="oe_stat_button"-->
<!--                                icon="fa-list"-->
<!--                                context="{'search_default_asset_class': active_id}"-->
<!--                                invisible="category_count == 0">-->
<!--                            <field name="category_count" widget="statinfo" string="Categories"/>-->
<!--                        </button>-->
<!--                    </div>-->
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Class Name..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                    <notebook>
                        <page string="Categories" name="categories">
                            <field name="category_ids">
                                <list editable="bottom">
                                    <field name="name" string="Category Name"/>
                                    <field name="active" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== SEARCH VIEW ==================== -->
    <record id="view_asset_class_search" model="ir.ui.view">
        <field name="name">asset.class.search</field>
        <field name="model">asset.class</field>
        <field name="arch" type="xml">
            <search string="Search Asset Classes">
                <field name="name" string="Class Name"
                       filter_domain="[('name', 'ilike', self)]"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Active" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="action_asset_class" model="ir.actions.act_window">
        <field name="name">Asset Classes</field>
        <field name="res_model">asset.class</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_asset_class_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Asset Class
            </p>
            <p>Asset Classes are the top-level classification for your assets (e.g. IT Equipment, Furniture, Vehicles).</p>
        </field>
    </record>

</odoo>
