<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== LIST VIEW ==================== -->
    <record id="view_asset_floor_location_list" model="ir.ui.view">
        <field name="name">asset.floor.location.list</field>
        <field name="model">asset.floor.location</field>
        <field name="arch" type="xml">
            <list string="Floor Locations" editable="bottom">
                <field name="name" string="Floor Name"/>
                <field name="office_location" string="Office Location"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ==================== FORM VIEW ==================== -->
    <record id="view_asset_floor_location_form" model="ir.ui.view">
        <field name="name">asset.floor.location.form</field>
        <field name="model">asset.floor.location</field>
        <field name="arch" type="xml">
            <form string="Floor Location">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Floor Location Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Location">
                            <field name="office_location" options="{'no_create': False}"/>
                        </group>
                        <group string="Status">
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== SEARCH VIEW ==================== -->
    <record id="view_asset_floor_location_search" model="ir.ui.view">
        <field name="name">asset.floor.location.search</field>
        <field name="model">asset.floor.location</field>
        <field name="arch" type="xml">
            <search string="Search Floor Locations">
                <field name="name" string="Floor Name"
                       filter_domain="[('name', 'ilike', self)]"/>
                <field name="office_location" string="Office Location"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Office Location" name="group_office"
                            context="{'group_by': 'office_location'}"/>
                    <filter string="Active" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="action_asset_floor_location" model="ir.actions.act_window">
        <field name="name">Floor Locations</field>
        <field name="res_model">asset.floor.location</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_asset_floor_location_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Floor Location
            </p>
            <p>Floor Locations define specific floors or levels within an Office Location.</p>
        </field>
    </record>

</odoo>
