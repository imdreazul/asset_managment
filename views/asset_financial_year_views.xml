<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== LIST VIEW ==================== -->
    <record id="view_asset_financial_year_list" model="ir.ui.view">
        <field name="name">asset.financial.year.list</field>
        <field name="model">asset.financial.year</field>
        <field name="arch" type="xml">
            <list string="Asset Financial Years" editable="bottom">
                <field name="name" string="Financial Year"/>
                <field name="start_date" string="Start Date"/>
                <field name="end_date" string="End Date"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ==================== FORM VIEW ==================== -->
    <record id="view_asset_financial_year_form" model="ir.ui.view">
        <field name="name">asset.financial.year.form</field>
        <field name="model">asset.financial.year</field>
        <field name="arch" type="xml">
            <form string="Asset Financial Year">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. FY 2024-2025"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Period">
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group string="Status">
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== SEARCH VIEW ==================== -->
    <record id="view_asset_financial_year_search" model="ir.ui.view">
        <field name="name">asset.financial.year.search</field>
        <field name="model">asset.financial.year</field>
        <field name="arch" type="xml">
            <search string="Search Financial Years">
                <field name="name" string="Financial Year"
                       filter_domain="[('name', 'ilike', self)]"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Active" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="action_asset_financial_year" model="ir.actions.act_window">
        <field name="name">Asset Financial Years</field>
        <field name="res_model">asset.financial.year</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_asset_financial_year_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Financial Year
            </p>
            <p>Financial Years define the fiscal periods for asset tracking and reporting.</p>
        </field>
    </record>



</odoo>
