<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== LIST VIEW ==================== -->
    <record id="view_asset_insurance_partner_list" model="ir.ui.view">
        <field name="name">asset.insurance.partner.list</field>
        <field name="model">asset.insurance.partner</field>
        <field name="arch" type="xml">
            <list string="Asset Insurance Partners">
                <field name="name" string="Insurance Partner"/>
                <field name="contact_person" string="Contact Person"/>
                <field name="contact_person_no" string="Contact Number"/>
                <field name="email" string="Email"/>
                <field name="website" string="Website"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ==================== FORM VIEW ==================== -->
    <record id="view_asset_insurance_partner_form" model="ir.ui.view">
        <field name="name">asset.insurance.partner.form</field>
        <field name="model">asset.insurance.partner</field>
        <field name="arch" type="xml">
            <form string="Asset Insurance Partner">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Insurance Partner Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Contact Information">
                            <field name="contact_person" placeholder="Full name of contact..."/>
                            <field name="contact_person_no" placeholder="+880 ..."/>
                            <field name="email" placeholder="email@example.com"/>
                            <field name="website" placeholder="https://www.example.com"/>
                        </group>
                        <group string="Status">
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== SEARCH VIEW ==================== -->
    <record id="view_asset_insurance_partner_search" model="ir.ui.view">
        <field name="name">asset.insurance.partner.search</field>
        <field name="model">asset.insurance.partner</field>
        <field name="arch" type="xml">
            <search string="Search Insurance Partners">
                <field name="name" string="Partner Name"
                       filter_domain="[('name', 'ilike', self)]"/>
                <field name="contact_person" string="Contact Person"
                       filter_domain="[('contact_person', 'ilike', self)]"/>
                <field name="email" string="Email"
                       filter_domain="[('email', 'ilike', self)]"/>
                <separator/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Active" name="group_active" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="action_asset_insurance_partner" model="ir.actions.act_window">
        <field name="name">Asset Insurance Partners</field>
        <field name="res_model">asset.insurance.partner</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_asset_insurance_partner_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first Insurance Partner
            </p>
            <p>Insurance Partners are companies or agents providing insurance coverage for assets.</p>
        </field>
    </record>

</odoo>
