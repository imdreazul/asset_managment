<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════
         DEPRECIATION LINE  –  List (inline inside asset form)
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_asset_depreciation_line_list" model="ir.ui.view">
        <field name="name">asset.depreciation.line.list</field>
        <field name="model">asset.depreciation.line</field>
        <field name="arch" type="xml">
            <list string="Depreciation Schedule"
                  editable="bottom"
                  decoration-info="written_down_value &gt; 0"
                  decoration-muted="written_down_value &lt;= 0">

                <field name="period_type" optional="show"/>
                <field name="date_from" string="From"/>
                <field name="date_to"   string="To"/>
                <field name="days"      string="Days"   readonly="1" optional="show"/>
                <field name="months"    string="Months" readonly="1" optional="hide"/>
                <field name="years"     string="Years"  readonly="1" optional="hide" digits="[16,4]"/>

                <!-- COST block -->
                <field name="cost_opening_balance"  string="Cost: Opening"    digits="[16,2]"/>
                <field name="cost_addition"         string="Cost: Addition"   digits="[16,2]"/>
                <field name="cost_adjustment"       string="Cost: Adjustment" digits="[16,2]"/>
                <field name="cost_closing_balance"  string="Cost: Closing"    digits="[16,2]" readonly="1"/>

                <!-- DEPRECIATION block -->
                <field name="dep_opening_balance"   string="Dep: Opening"     digits="[16,2]"/>
                <field name="dep_charge"            string="Dep: Charge"      digits="[16,2]" readonly="1"/>
                <field name="dep_adjustment"        string="Dep: Adjustment"  digits="[16,2]"/>
                <field name="dep_closing_balance"   string="Dep: Closing"     digits="[16,2]" readonly="1"/>

                <!-- KM column  – visible only for km_per_hour method -->
                <field name="km_this_period"
                       string="KM / Usage"
                       digits="[16,2]"
                       optional="hide"/>

                <!-- WDV -->
                <field name="written_down_value" string="WDV" digits="[16,2]" readonly="1"/>

                <!-- hidden relation needed for domain/context -->
                <field name="depreciation_method" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         DEPRECIATION LINE  –  Standalone list (menu / action)
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_asset_depreciation_line_list_standalone" model="ir.ui.view">
        <field name="name">asset.depreciation.line.list.standalone</field>
        <field name="model">asset.depreciation.line</field>
        <field name="arch" type="xml">
            <list string="All Depreciation Lines"
                  decoration-info="written_down_value &gt; 0"
                  decoration-muted="written_down_value &lt;= 0"
                  default_order="date_from asc">

                <field name="asset_id"              string="Asset"/>
                <field name="depreciation_method"   string="Method"/>
                <field name="period_type"           string="Period"/>
                <field name="date_from"             string="From"/>
                <field name="date_to"               string="To"/>
                <field name="days"                  string="Days"/>
                <field name="cost_opening_balance"  string="Cost Opening"  digits="[16,2]"/>
                <field name="cost_addition"         string="Addition"      digits="[16,2]"/>
                <field name="cost_adjustment"       string="Cost Adj."     digits="[16,2]"/>
                <field name="cost_closing_balance"  string="Cost Closing"  digits="[16,2]"/>
                <field name="dep_opening_balance"   string="Dep Opening"   digits="[16,2]"/>
                <field name="dep_charge"            string="Dep Charge"    digits="[16,2]"/>
                <field name="dep_adjustment"        string="Dep Adj."      digits="[16,2]"/>
                <field name="dep_closing_balance"   string="Dep Closing"   digits="[16,2]"/>
                <field name="written_down_value"    string="WDV"           digits="[16,2]"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         DEPRECIATION LINE  –  Form (detail view for one line)
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_asset_depreciation_line_form" model="ir.ui.view">
        <field name="name">asset.depreciation.line.form</field>
        <field name="model">asset.depreciation.line</field>
        <field name="arch" type="xml">
            <form string="Depreciation Line">
                <sheet>
                    <group string="Period">
                        <group>
                            <field name="asset_id" readonly="1"/>
                            <field name="depreciation_method" readonly="1"/>
                            <field name="period_type"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                        <group string="Duration">
                            <field name="days"   readonly="1"/>
                            <field name="months" readonly="1"/>
                            <field name="years"  readonly="1" digits="[16,4]"/>
                        </group>
                    </group>

                    <group string="Cost of Asset">
                        <group>
                            <field name="cost_opening_balance"/>
                            <field name="cost_addition"/>
                            <field name="cost_adjustment"/>
                        </group>
                        <group>
                            <field name="cost_closing_balance" readonly="1"/>
                        </group>
                    </group>

                    <group string="Depreciation">
                        <group>
                            <field name="dep_opening_balance"/>
                            <field name="dep_charge"       readonly="1"/>
                            <field name="dep_adjustment"/>
                        </group>
                        <group>
                            <field name="dep_closing_balance" readonly="1"/>
                            <field name="written_down_value"  readonly="1"/>
                        </group>
                    </group>

                    <!-- KM / Usage block – shown only for km_per_hour method -->
                    <group string="KM / Usage Details"
                           invisible="depreciation_method != 'km_per_hour'">
                        <field name="km_this_period"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         DEPRECIATION LINE  –  Search
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_asset_depreciation_line_search" model="ir.ui.view">
        <field name="name">asset.depreciation.line.search</field>
        <field name="model">asset.depreciation.line</field>
        <field name="arch" type="xml">
            <search string="Search Depreciation Lines">
                <field name="asset_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <separator/>
                <filter string="Reducing Balance"  name="reducing"
                        domain="[('asset_id.depreciation_method','=','reducing')]"/>
                <filter string="Straight Line"     name="straight_line"
                        domain="[('asset_id.depreciation_method','=','straight_line')]"/>
                <filter string="KM / Per Hour"     name="km_per_hour"
                        domain="[('asset_id.depreciation_method','=','km_per_hour')]"/>
                <group expand="0" string="Group By">
                    <filter string="Asset"  name="group_asset"  context="{'group_by':'asset_id'}"/>
<!--                    <filter string="Method" name="group_method" context="{'group_by':'asset_id.depreciation_method'}"/>-->
                    <filter string="Period" name="group_period" context="{'group_by':'period_type'}"/>
                    <filter string="Year"   name="group_year"   context="{'group_by':'date_from:year'}"/>
                    <filter string="Month"  name="group_month"  context="{'group_by':'date_from:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         DEPRECIATION LINE  –  Window Action (standalone menu)
    ═══════════════════════════════════════════════════════════════ -->
    <record id="action_asset_depreciation_line" model="ir.actions.act_window">
        <field name="name">Depreciation Schedule</field>
        <field name="res_model">asset.depreciation.line</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'group_by': 'asset_id'}</field>
        <field name="view_id" ref="view_asset_depreciation_line_list_standalone"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No depreciation lines yet.
            </p>
            <p>
                Open an asset, enable depreciation, and use the
                <b>Generate Schedule</b> button to create lines.
            </p>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         GENERATE SCHEDULE WIZARD  –  Form
    ═══════════════════════════════════════════════════════════════ -->
    <record id="view_asset_depreciation_generate_wizard_form" model="ir.ui.view">
        <field name="name">asset.depreciation.generate.wizard.form</field>
        <field name="model">asset.depreciation.generate.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Depreciation Schedule">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle me-2"/>
                        This wizard will auto-generate depreciation period lines for the
                        selected asset. Opening balances are chained automatically.
                    </div>
                    <group>
                        <group string="Asset">
                            <field name="asset_id" readonly="1"/>
                            <field name="depreciation_method" readonly="1"/>
                        </group>
                        <group string="Schedule Parameters">
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="period_type"/>
                            <field name="delete_existing"/>
                        </group>
                    </group>
                    <div class="alert alert-warning"
                         invisible="not delete_existing"
                         role="alert">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <strong>Warning:</strong> All existing depreciation lines for this
                        asset will be permanently deleted before generating the new schedule.
                    </div>
                </sheet>
                <footer>
                    <button name="action_generate"
                            string="Generate Schedule"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
